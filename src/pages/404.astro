---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found">
  <div class="flex items-center justify-center min-h-[60vh] px-6">
    <div class="text-center">
      <p class="text-muted text-xs uppercase tracking-widest mb-4 font-mono">404</p>
      <h1 class="text-4xl md:text-5xl mb-4">Page not found</h1>
      <p class="text-muted text-lg mb-8 max-w-md mx-auto leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-block px-6 py-2.5 bg-surface border border-border rounded-sm text-text hover:border-accent hover:text-accent transition-colors text-sm"
      >
        Back to homepage
      </a>
    </div>
  </div>
</BaseLayout>
