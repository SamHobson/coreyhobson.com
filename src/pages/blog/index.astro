---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate, slugFromId } from "../../utils/format";

const allPosts = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="Writing on UX, product design, gaming, and tools.">
  <section class="max-w-3xl mx-auto px-6 pt-24 pb-12">
    <h1 class="text-4xl md:text-5xl mb-4">Blog</h1>
    <p class="text-muted text-lg">
      Writing on UX, product design, gaming, and the tools that support the work.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-24">
    <div class="flex flex-col gap-0 border-t border-border">
      {allPosts.map((post) => (
        <a
          href={`/blog/${slugFromId(post.id)}`}
          class="group flex flex-col sm:flex-row sm:items-start justify-between gap-2 py-6 border-b border-border hover:pl-2 transition-all"
        >
          <div class="flex-1">
            <h2 class="text-lg mb-1 group-hover:text-accent transition-colors">
              {post.data.title}
            </h2>
            <p class="text-muted text-sm leading-relaxed">
              {post.data.description}
            </p>
          </div>
          <time datetime={post.data.date.toISOString()} class="text-muted text-sm font-mono shrink-0 sm:mt-1">
            {formatDate(post.data.date, { year: "numeric", month: "short", day: "numeric" })}
          </time>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
