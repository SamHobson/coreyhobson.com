---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allProjects = (await getCollection("projects"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Projects" description="Personal projects: games, tools, AI experiments, and more.">
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-12">
    <h1 class="text-4xl md:text-5xl mb-4">Projects</h1>
    <p class="text-muted text-lg max-w-2xl">
      Things built outside of work. Games, tools, experiments.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {allProjects.map((project) => (
        <a
          href={`/projects/${project.id.replace(/\.md$/, "")}`}
          class="group block bg-surface border border-border rounded-sm overflow-hidden hover:border-accent/40 transition-colors"
        >
          {project.data.image && (
            <div class="aspect-video overflow-hidden">
              <img
                src={project.data.image}
                alt={project.data.title}
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <h2 class="text-lg group-hover:text-accent transition-colors">
                {project.data.title}
              </h2>
              <span class="text-xs text-muted font-mono uppercase">
                {project.data.status}
              </span>
            </div>
            <p class="text-muted text-sm leading-relaxed mb-4">
              {project.data.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {project.data.tags.map((tag: string) => (
                <span class="text-xs text-muted font-mono">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
