---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { formatDate, slugFromId } from "../../utils/format";

export async function getStaticPaths() {
  const entries = await getCollection("projects");
  return entries.map((entry) => ({
    params: { slug: slugFromId(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  type="article"
>
  <article class="max-w-3xl mx-auto px-6 pt-24 pb-24">
    <header class="mb-12">
      {entry.data.image && (
        <div class="aspect-video overflow-hidden mb-8 rounded-sm">
          <img
            src={entry.data.image}
            alt={entry.data.title}
            class="w-full h-full object-cover"
            width="800"
            height="450"
          />
        </div>
      )}
      <p class="text-muted text-xs uppercase tracking-widest mb-4 font-mono">
        {formatDate(entry.data.date)} &middot; {entry.data.status}
      </p>
      <h1 class="text-4xl md:text-5xl mb-6">{entry.data.title}</h1>
      <p class="text-muted text-lg leading-relaxed">{entry.data.description}</p>
      <div class="flex items-center gap-4 mt-4">
        {entry.data.repo && (
          <a
            href={entry.data.repo}
            class="text-accent hover:text-accent-hover text-sm"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="opens in new tab"
          >
            Source code &rarr;
          </a>
        )}
        {entry.data.live_url && (
          <a
            href={entry.data.live_url}
            class="text-accent hover:text-accent-hover text-sm"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="opens in new tab"
          >
            Live site &rarr;
          </a>
        )}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-border">
      <a href="/projects" class="text-muted hover:text-text text-sm transition-colors">
        &larr; All projects
      </a>
    </footer>
  </article>
</BaseLayout>
